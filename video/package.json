{
  "name": "boom-video",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion sub-project for BOOM marketing videos",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render BrandPromo out/brand-promo.mp4",
    "render:signal": "remotion render SignalAlert out/signal-alert.mp4",
    "render:proof": "remotion render BoomProof out/boom-proof.mp4",
    "render:entry": "remotion render BoomEntry out/boom-entry.mp4",
    "templates:list": "node scripts/list-templates.js",
    "template:render": "node scripts/render-template.js",
    "template:create": "node scripts/create-template.js",
    "editor": "node editor/server.js",
    "regen:brand-promo-cards": "node scripts/generate-brand-promo-cards.js",
    "generate:brand-story": "node scripts/generate-brand-story.js",
    "worker": "tsx scripts/render-worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@remotion/animation-utils": "^4.0.459",
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.459",
    "@remotion/paths": "^4.0.459",
    "@remotion/renderer": "^4.0.0",
    "@remotion/shapes": "^4.0.459",
    "@remotion/transitions": "^4.0.457",
    "@remotion/zod-types": "^4.0.459",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "remotion": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@types/react": "^18.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
