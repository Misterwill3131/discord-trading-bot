# ─────────────────────────────────────────────────────────────────────
# .env.example — Variables d'environnement attendues par le bot
# ─────────────────────────────────────────────────────────────────────
# Copier vers `.env` (ne JAMAIS commit) ou définir directement dans le
# panneau Variables Railway. Toutes les variables liées au SaaS sont
# OPTIONNELLES — si SAAS_BOT_TOKEN est absent, la couche SaaS reste dormante
# et le bot trading actuel fonctionne comme avant.
# ─────────────────────────────────────────────────────────────────────

# === BOT TRADING (existant) ==========================================
# Token Discord du bot principal (écoute #trading-floor sur le serveur source).
DISCORD_TOKEN=

# Channel name à écouter (substring match, par défaut "trading-floor").
TRADING_CHANNEL=trading-floor

# Channel IDs Discord pour profits / news / alertes trading (pas obligatoires).
PROFITS_CHANNEL_ID=
NEWS_CHANNEL_ID=
TRADING_ALERTS_CHANNEL_ID=

# Webhook Make.com (existant — relais externe pour automation).
MAKE_WEBHOOK_URL=

# Email Resend pour alertes analyste (optionnel).
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# Auth dashboard (existant).
DASHBOARD_PASSWORD=
TRADING_PASSWORD=

# Port HTTP (Railway le set automatiquement).
PORT=3000

# === BOT SAAS RELAIS (nouveau, optionnel) ============================
# Token de la 2e application Discord créée pour le SaaS. Si vide, toute la
# couche SaaS reste désactivée (relais, slash commands, guildCreate guard).
# IMPORTANT : ne PAS activer le privileged intent "Message Content" sur ce
# bot — il publie, n'a pas besoin de lire le contenu des messages clients.
SAAS_BOT_TOKEN=

# Application ID (= Client ID) du bot SaaS — visible dans le Developer Portal,
# onglet "General Information". Sert à construire l'URL d'invitation OAuth.
SAAS_BOT_CLIENT_ID=

# Guild ID où enregistrer les commandes /saas admin. Doit être un serveur
# QUE TU POSSÈDES (pas le serveur source si tu n'en es pas owner). Le bot
# SaaS doit y être invité. Ces commandes seront visibles UNIQUEMENT sur ce
# guild — pas sur les serveurs des clients payants.
ADMIN_GUILD_ID=

# Optionnel : ton user ID Discord pour gate supplémentaire des commandes admin.
# Si défini, seul cet utilisateur peut exécuter /saas add|suspend|...
# Si vide, on s'appuie uniquement sur la perm Administrator du guild admin
# (utile si tu veux laisser tous les admins de ton guild gérer les licences).
ADMIN_USER_ID=

# Guild ID du serveur source (où les analystes postent). Filtre fort : le
# relais ignore les messages provenant de tout autre guild. Ce guild est
# distinct de ADMIN_GUILD_ID — il peut appartenir à un tiers (ex: ton
# employeur) sans que tu n'en sois admin.
SOURCE_GUILD_ID=

# Channel IDs (csv) à écouter sur le serveur source. Vide = relais désactivé.
# Ex: SOURCE_CHANNEL_IDS=111222333444555666,777888999000111222
SOURCE_CHANNEL_IDS=

# Identité visuelle des embeds relayés. BRAND_NAME apparaît dans le footer
# "via X". BRAND_COLOR au format hex (avec ou sans 0x/#). BRAND_THUMBNAIL_URL
# doit être une URL HTTPS publique (sinon ignorée).
BRAND_NAME=Trading Signals
BRAND_COLOR=0x06b6d4
BRAND_THUMBNAIL_URL=

# === LAUNCHPASS / STRIPE (Phase 2) ===================================
# Secret HMAC partagé avec Launchpass — vérifie que les webhooks reçus
# proviennent bien d'eux. Header attendu : X-Launchpass-Signature.
LAUNCHPASS_WEBHOOK_SECRET=

# Fallback Stripe (utilisé seulement si Launchpass ne fournit pas les
# webhooks attendus). Voir Phase 2 du plan SaaS.
STRIPE_WEBHOOK_SECRET=

# === DB POSTGRES PARTAGÉE AVEC LE SITE ================================
# Connection string Neon Postgres (même DB que temple-of-boom-site sur Vercel).
# Le bot l'utilise pour /connect <claim_code> : query customers WHERE claim_code=X,
# puis INSERT licenses linkant guild_id ↔ customer.
#
# Optionnelle : si vide, le bot fall-back sur le flow SQLite legacy
# (Launchpass pending_subs en KV) — /connect avec un code Stripe ne fonctionnera pas.
#
# À récupérer depuis Vercel → projet temple-of-boom-site → Settings → Storage
# → Neon (DATABASE_URL). À set sur Railway en var d'env.
DATABASE_URL=

# ─── Trend module (intraday scan + !trend command) ────────────────────
# All values are optional — defaults shown apply if unset.
# TREND_SCAN_INTERVAL_MIN=5
# TREND_BREAKOUT_LOOKBACK_BARS=20
# TREND_BREAKOUT_VOLUME_MULT=1.5
# TREND_DEDUP_MINUTES=60
# TREND_RSI_OVERBOUGHT=70
# TREND_RSI_OVERSOLD=30

# ─── Trend module — daily-reference signals (PDH/PDL/gap/volume) ──────
# All values are optional — defaults shown apply if unset.
# TREND_PDH_PDL_REENTRY_MIN=15
# TREND_GAP_THRESHOLD_INDEX_PCT=0.5
# TREND_GAP_THRESHOLD_STOCK_PCT=1.5
# TREND_VOLUME_VS_PREV_PCT=5

# === PHASE 3 — AUTO-RENDER DES PROOF VIDEOS ==========================
# Le bot enqueue un job dans `render_jobs` à chaque exit gagnant matchable.
# Un worker local (cd video && npm run worker) poll /api/render-queue,
# render via Remotion, et upload le MP4 multipart au bot pour publication
# Discord dans RENDER_OUTPUT_CHANNEL_ID.

# Token partagé entre bot et worker pour Bearer auth sur les endpoints
# /api/render-queue. Génère avec : openssl rand -hex 32
# Doit être identique côté bot (Railway) ET côté worker (machine locale).
RENDER_WORKER_TOKEN=

# ID du canal Discord où le bot poste les vidéos rendues.
# Clic-droit sur le canal Discord → Copy Channel ID (mode dev requis).
RENDER_OUTPUT_CHANNEL_ID=

# URL publique du bot — utilisée UNIQUEMENT côté worker local pour atteindre
# le bot Railway. Côté bot Railway, cette var n'est pas utilisée.
# Ex : https://boom-bot-production.up.railway.app
BOT_URL=
